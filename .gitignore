.claude/
CLAUDE.md

# Unrelated working files in this directory
writing-submissions.md

# Python cache
__pycache__/
*.pyc

# Rendered video outputs (large binaries)
Resources/*.mp4

# MobileCLIP-S2 CoreML weights — too large for GitHub (>100MB single-file limit).
# Fetched on first build by scripts/fetch-clip-models.sh.
Sources/tvara/Resources/Models/*.mlmodelc/
Sources/tvara/Resources/Models/clip-vocab.json
Sources/tvara/Resources/Models/clip-merges.txt

# Image-search prototype (large model weights live here too)
imagesearch/models/
imagesearch/clip_search
imagesearch/image_search
imagesearch/index.json
imagesearch/clip_index.json
imagesearch/ImageSearch.app/
imagesearch/runs/

# Secrets — never commit
.env
*.env
.env.swift
**/.env.swift
openai_key.txt

# Embedding eval — contains real Discord messages; rebuild locally with
# scripts/embeddings/build_eval.py + bench_text.py
scripts/embeddings/eval_dataset.json
scripts/embeddings/last_text_run.json
scripts/embeddings/last_image_run.json
scripts/embeddings/cache/*
!scripts/embeddings/cache/.gitignore
scripts/embeddings/archive/ground_truth_v1.json
scripts/embeddings/archive/last_text_run_v1.json
